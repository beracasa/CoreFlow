# Copy to `.env.local` for local development (this file is safe to commit).
#
# Mock mode (no real DB writes):
# VITE_USE_MOCK=true
#
# Live mode (Supabase):
# VITE_USE_MOCK=false
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your anon key>
#
# In Vercel, set these as Environment Variables (Preview/Staging/Production as needed).
VITE_USE_MOCK=true
VITE_SUPABASE_URL=https://placeholder-url.supabase.co
VITE_SUPABASE_ANON_KEY=placeholder-key-for-development-only
